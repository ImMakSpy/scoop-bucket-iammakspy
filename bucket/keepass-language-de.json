    "depends": "extras/keepass",
    "installer": {
        "script": "Copy-Item \"$dir\\German.lngx\" \"$(appdir keepass $global)\\current\\Languages\""
    },
    "uninstaller": {
        "script": "Remove-Item \"$(appdir keepass $global)\\current\\Languages\\German.lngx\""
    },
    "checkver": {
